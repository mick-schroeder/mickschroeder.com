---
import Button from "@/components/ui/astro/Button.astro";
import Card from "@/components/ui/astro/Card.astro";
import Mail from "@lucide/astro/icons/mail";
import type { Dictionary } from "@/i18n/config";

interface Props {
  email?: string;
  dict: Dictionary;
}

const { email, dict } = Astro.props;
if (!email) {
  throw new Error("Contact component requires an email address.");
}
---

<div class="mt-8 grid gap-6">
  <Card class="animate-rise">
    <div slot="header" class="flex items-center gap-4">
      <span class="inline-grid h-11 w-11 place-items-center rounded-2xl bg-primary/12 text-primary ring-1 ring-border">
        <Mail class="h-4 w-4" />
      </span>
      <div>
        <h3 class="text-xl font-semibold tracking-[-0.02em]">{dict["title_email"]}</h3>
        <a
          href={`mailto:${email}`}
          class="text-sm text-muted-foreground underline decoration-primary/35 underline-offset-4 hover:text-primary"
        >
          {email}
        </a>
      </div>
    </div>
    <div slot="content" class="pt-0">
      <p class="mb-5 max-w-xl text-base leading-7 text-muted-foreground">
        {dict["contact_body"]}
      </p>
      <Button
        href={`mailto:${email}`}
        variant="outline"
        className="w-full sm:w-auto"
      >
        {dict["cta_email"]}
        <Mail class="h-4 w-4" />
      </Button>
    </div>
  </Card>
</div>
