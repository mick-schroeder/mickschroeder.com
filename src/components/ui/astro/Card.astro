---
import { cn } from "@/lib/utils";

type Props = {
  class?: string;
  className?: string;
  headerClass?: string;
  contentClass?: string;
  footerClass?: string;
};

const {
  class: classAttr = "",
  className = classAttr,
  headerClass = "",
  contentClass = "",
  footerClass = "",
} = Astro.props as Props;
---

<article class={cn("overflow-hidden rounded-[1.75rem] border border-border/70 bg-card/90 text-card-foreground shadow-[0_28px_70px_-42px_rgba(22,18,13,0.45)] backdrop-blur supports-[backdrop-filter]:bg-card/82 dark:shadow-[0_28px_70px_-42px_rgba(0,0,0,0.65)]", className)}>
  {Astro.slots.has("header") && (
    <div class={cn("flex items-center gap-3 px-6 py-5", headerClass)}>
      <slot name="header" />
    </div>
  )}

  {Astro.slots.has("content") ? (
    <div class={cn("px-6 pb-6", contentClass)}>
      <slot name="content" />
    </div>
  ) : (
    <slot />
  )}

  {Astro.slots.has("footer") && (
    <div class={cn("border-t border-border/60 px-6 py-5", footerClass)}>
      <slot name="footer" />
    </div>
  )}
</article>
